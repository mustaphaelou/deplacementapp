# Required environment variables.
#
# Production (Coolify): set each of these in the Coolify UI — compose.yaml marks
# them required with ${VAR:?} and Coolify surfaces them there. DATABASE_URL points
# at the Coolify-managed Postgres; NEXTAUTH_URL is your public URL; SMTP_* is your
# mail relay.
#
# Development: copy this file to .env. docker compose reads .env automatically
# for variable interpolation, and prisma.config.js loads it via dotenv.

# Database — dev value matches the throwaway db service in compose.dev.yml
DATABASE_URL=postgresql://user:pass@localhost:5432/deplacementapp

# Dev-only: credentials for the throwaway db service in compose.dev.yml
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=deplacementapp

# Auth (next-auth v5)
# Prod: generate a long random string (e.g. `openssl rand -base64 32`)
NEXTAUTH_SECRET=dev-secret-not-for-production-use
NEXTAUTH_URL=http://localhost:3000
# Dev only: lets next-auth trust the local host without NEXTAUTH_URL matching
AUTH_TRUST_HOST=true

# SMTP — dev values point at mailpit (compose.dev.yml); web UI on http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@exemple.ma
