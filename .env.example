# =============================================================================
# Environment Variables — deplacementapp
# =============================================================================
# Set these in Coolify → Environment Variables for production.
# docker-compose.yaml interpolates them at deploy time.
# =============================================================================

# PostgreSQL — required (fallbacks exist in compose but set these for security)
POSTGRES_USER="user"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="deplacementapp"

# DATABASE_URL is composed from the POSTGRES_* vars in docker-compose.yaml,
# so you do NOT need to set it separately in Coolify. It's shown here only
# for local development reference.
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}"

# NextAuth — both REQUIRED in production (no fallbacks, app won't start without)
NEXTAUTH_SECRET="generate-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="https://your-coolify-app-domain.com"

# Already hardcoded in docker-compose.yaml; shown here for reference only.
AUTH_TRUST_HOST=true

# SMTP (optional — app works without it, but email notifications won't send)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.ma"
