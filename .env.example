# =============================================================================
# Environment Variables — deplacementapp
# =============================================================================
# Set these in Coolify → Environment Variables for production.
# docker-compose.yaml interpolates them at deploy time.
# =============================================================================

# PostgreSQL — required. In Coolify, set these AND set DATABASE_URL to the
# actual Coolify-provided PostgreSQL connection string (host ≠ "db" in production).
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=deplacementapp

# REQUIRED in production. Set this to the actual Coolify PostgreSQL connection
# URL — the ${VAR} syntax below does NOT expand on Coolify. Replace the whole
# value with the one Coolify gives you, e.g.:
#   postgresql://user:password@coolify-instance.internal:5432/deplacementapp
DATABASE_URL=postgresql://user:change-me@your-db-host:5432/deplacementapp

# NextAuth — both REQUIRED in production (no fallbacks, app won't start without)
NEXTAUTH_SECRET=<your-random-secret-at-least-32-chars>
NEXTAUTH_URL=https://your-coolify-app-domain.com

AUTH_TRUST_HOST=true

# SMTP (optional — app works without it, but email notifications won't send)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.ma
