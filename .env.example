# =============================================================================
# Environment Variables — deplacementapp
# =============================================================================
# Production: set these in Coolify → Environment → Variables.
# Local dev:  copy this file to .env and fill in the values.
# =============================================================================
#
#  ┌───────────────────────────────────────────────────────────────────┐
#  │  COOLIFY DEPLOYMENT                                              │
#  │                                                                   │
#  │  1. Create a PostgreSQL add-on in Coolify                         │
#  │  2. Copy the internal connection URL from Coolify                 │
#  │  3. Set DATABASE_URL below to that URL                            │
#  │                                                                   │
#  │  Do NOT use ${VAR} syntax — Coolify does not expand variables     │
#  │  inside compose files. Paste the actual PostgreSQL connection URL │
#  │  directly as the value of DATABASE_URL, e.g.:                     │
#  │    postgresql://user:password@coolify-instance.internal:5432/db   │
#  └───────────────────────────────────────────────────────────────────┘

# PostgreSQL (required)
# Paste the INTERNAL connection URL from your Coolify PostgreSQL resource,
# with the database name changed to this app's dedicated database:
DATABASE_URL=postgresql://postgres:<password-from-coolify>@<postgres-container-name>:5432/deplacementapp

# NextAuth (required — app won't start without these)
NEXTAUTH_SECRET=<your-random-secret-at-least-32-chars>
NEXTAUTH_URL=https://your-coolify-app-domain.com

AUTH_TRUST_HOST=true

# SMTP (optional — app works without it, but email notifications won't send)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.ma

# ─────────────────────────────────────────────────────────────────────
# Local dev only — not needed in production / Coolify.
# These are used by compose.dev.yml when running the built-in PostgreSQL
# container. The dev override hardcodes them for convenience.
# ─────────────────────────────────────────────────────────────────────
# POSTGRES_USER=user
# POSTGRES_PASSWORD=pass
# POSTGRES_DB=hay2010
